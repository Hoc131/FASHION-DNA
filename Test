def call_gemini(contents, models=None):
    if models is None:
        models = GEMINI_MODELS
    for model_name in models:
        for attempt in range(2):
            try:
                response = client.models.generate_content(
                    model=model_name,
                    contents=contents
                )
                print(f"✅ Dùng model: {model_name}")
                return response
