import torch
import numpy as np
import cv2
import matplotlib.pyplot as plt
from pytorch_grad_cam import GradCAM
from pytorch_grad_cam.utils.model_targets import ClassifierOutputTarget
from pytorch_grad_cam.utils.image import show_cam_on_image

# General wrapper for each task
class TaskWrapper(torch.nn.Module):
    def __init__(self, model, task_name):
        super(TaskWrapper, self).__init__()
        self.model = model
        self.task_name = task_name
    def forward(self, x):
        outputs, _ = self.model(x)
        return outputs[self.task_name]

tasks = ["gender", "master_cat", "sub_cat", "article_type", "base_colour", "season"]

# Create figure: 2 rows x 4 columns (Original + 6 heatmaps + 1 empty space to delete)
fig, axes = plt.subplots(2, 4, figsize=(18,10))

# First subplot: Original Image (English Label for Publication)
axes[0,0].imshow(img)
axes[0,0].axis("off")
axes[0,0].set_title("Original Image", fontsize=12, fontweight="bold")

# Convert original image to numpy float32 once
img_np = np.array(img).astype(np.float32) / 255.0

# Run Grad-CAM over 6 tasks
for ax, task in zip(axes.flat[1:], tasks):
    wrapped_model = TaskWrapper(model, task)
    # Hook into patch_embed.proj for 4D feature map
    cam = GradCAM(model=wrapped_model, target_layers=[model.backbone.patch_embed.proj])

    outputs, _ = model(img_tensor)
    pred_class = torch.argmax(outputs[task], dim=1).item()
    targets = [ClassifierOutputTarget(pred_class)]

    grayscale_cam = cam(input_tensor=img_tensor, targets=targets)[0, :]

    # Resize heatmap back to original image size
    grayscale_cam_resized = cv2.resize(grayscale_cam, (img_np.shape[1], img_np.shape[0]))

    visualization = show_cam_on_image(img_np, grayscale_cam_resized, use_rgb=True)

    ax.imshow(visualization)
    ax.axis("off")
    ax.set_title(f"{task}", fontsize=12, fontweight="bold")

# REMOVE THE UNUSED 8TH SUBPLOT FOR PERFECT PAPER GRID
fig.delaxes(axes[1, 3])

plt.tight_layout()
plt.show()


