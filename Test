def plot_model_architecture():
    # Khởi tạo đồ thị có hướng, vẽ theo chiều ngang (LR)
    dot = Digraph(comment='HydraSwin Architecture', format='png')
    dot.attr(rankdir='LR', splines='ortho', nodesep='0.5', ranksep='1.0')
    dot.attr('node', shape='box', style='filled,rounded', fontname='Arial', fontsize='12')

    # Định nghĩa các Node (Các cục trong mô hình)
    dot.node('A', 'Input Image\n(224x224x3)', fillcolor='#E8E8E8')
    dot.node('B', 'Swin-Tiny Backbone\n(Shifted Window Attention)', fillcolor='#D5E8D4', penwidth='2')
    dot.node('C', 'Shared Feature Vector\n(768-Dimensional)', fillcolor='#FFF2CC', penwidth='2')

    # Định nghĩa 6 classification heads
    heads = {
        'T1': 'Gender Head\n(5 classes)',
        'T2': 'Master Cat Head\n(7 classes)',
        'T3': 'Sub Cat Head\n(45 classes)',
        'T4': 'Article Type Head\n(142 classes)',
