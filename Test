5.Định nghĩa kiến trúc mô hình HydraSwin:
import torch.nn as nn
import timm

class HydraSwin(nn.Module):
    def __init__(self, num_classes_dict):
        super(HydraSwin, self).__init__()
        # backbone Swin Transformer
        self.backbone = timm.create_model("swin_tiny_patch4_window7_224", pretrained=True, num_classes=0)
        in_features = self.backbone.num_features

        # tạo head cho từng task (đặt tên giống lúc train)
        self.gender_head = nn.Linear(in_features, num_classes_dict["gender"])
        self.master_cat_head = nn.Linear(in_features, num_classes_dict["master_cat"])
        self.sub_cat_head = nn.Linear(in_features, num_classes_dict["sub_cat"])
        self.article_type_head = nn.Linear(in_features, num_classes_dict["article_type"])
        self.base_colour_head = nn.Linear(in_features, num_classes_dict["base_colour"])
        self.season_head = nn.Linear(in_features, num_classes_dict["season"])

    def forward(self, x):
        features = self.backbone(x)
        outputs = {
            "gender": self.gender_head(features),
            "master_cat": self.master_cat_head(features),
            "sub_cat": self.sub_cat_head(features),
            "article_type": self.article_type_head(features),
            "base_colour": self.base_colour_head(features),
            "season": self.season_head(features)
        }
        return outputs, features

