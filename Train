🔟 Tạo Dataset class


class FashionDataset(Dataset):

    def __init__(self, dataframe, transform=None):
        self.df = dataframe
        self.transform = transform

    def __len__(self):
        return len(self.df)

    def __getitem__(self, idx):

        img_path = self.df.iloc[idx]["image"]
        image = Image.open(img_path).convert("RGB")

        if self.transform:
            image = self.transform(image)

        label_type = self.df.iloc[idx]["articleType"]
        label_color = self.df.iloc[idx]["baseColour"]
        label_season = self.df.iloc[idx]["season"]

        return image, label_type, label_color, label_season


11️⃣ DataLoader


train_dataset = FashionDataset(train_df, transform)
val_dataset = FashionDataset(val_df, transform)

train_loader = DataLoader(train_dataset, batch_size=32, shuffle=True)
val_loader = DataLoader(val_dataset, batch_size=32)


12️⃣ Model Fashion DNA (multi-head)


class FashionModel(nn.Module):

    def __init__(self, num_type, num_color, num_season):
        super().__init__()

        self.backbone = models.resnet50(pretrained=True)
        self.backbone.fc = nn.Identity()

        self.head_type = nn.Linear(2048, num_type)
        self.head_color = nn.Linear(2048, num_color)
        self.head_season = nn.Linear(2048, num_season)

    def forward(self, x):

        features = self.backbone(x)

        type_out = self.head_type(features)
        color_out = self.head_color(features)
        season_out = self.head_season(features)

        return type_out, color_out, season_out


13️⃣ Khởi tạo model


device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

model = FashionModel(
    num_type=df["articleType"].nunique(),
    num_color=df["baseColour"].nunique(),
    num_season=df["season"].nunique()
).to(device)


14️⃣ Loss và optimizer


criterion = nn.CrossEntropyLoss()
optimizer = torch.optim.Adam(model.parameters(), lr=1e-4)


15️⃣ Training loop


epochs = 5

for epoch in range(epochs):

    model.train()

    for images, t, c, s in train_loader:

        images = images.to(device)
        t = t.to(device)
        c = c.to(device)
        s = s.to(device)

        optimizer.zero_grad()

        out_t, out_c, out_s = model(images)

        loss = (
            criterion(out_t, t) +
            criterion(out_c, c) +
            criterion(out_s, s)
        )

        loss.backward()
        optimizer.step()

    print("Epoch:", epoch, "Loss:", loss.item())
